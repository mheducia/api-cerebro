    "version": "0.2.0",
    "configurations": [
        {
        "name": "API Python - Cérebro",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
            "main:app",
            "--reload",
            "--port",
            "8001"
        ],
        "jinja": true,
        "justMyCode": true,
        "cwd": "${workspaceFolder}",
        "envFile": "${workspaceFolder}/.env",
        "python": "${workspaceFolder}/venv/Scripts/python.exe"
        }
    ]
}